<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="myBean" class="com.example.demo.GreetingService"/>

<!--    email service-->
    <bean id="emailService" class="com.example.loose.EmailNotification" />

<!--    notification Service-->
    <bean id="SmsService"  class="com.example.loose.SMS"/>

<!--    userService for email-->
    <bean id="UserServiceEmail" class="com.example.loose.UserService">
        <property name="notificationService" ref="emailService"
/>
    </bean>

<!--    userService for SMS-->
    <bean id="UserServiceSms" class="com.example.loose.UserService">
        <property name="notificationService" ref="SmsService"
        />
    </bean>

</beans>